<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvYearLabel"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:background="@color/black"
            android:text="@string/year"
            android:textColor="@color/red"
            android:textSize="36sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvMonthLabel"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:background="@color/black"
            android:text="@string/month"
            android:textColor="@color/red"
            android:textSize="36sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvDayLabel"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:background="@color/black"
            android:text="@string/day"
            android:textColor="@color/red"
            android:textSize="36sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvHourLabel"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:background="@color/black"
            android:text="@string/hour"
            android:textColor="@color/red"
            android:textSize="36sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvMinuteLabel"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:background="@color/black"
            android:text="@string/minute"
            android:textColor="@color/red"
            android:textSize="36sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/etYear"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:inputType="number"
            android:hint="YYYY"/>

        <EditText
            android:id="@+id/etMonth"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:inputType="number"
            android:hint="MM"/>

        <EditText
            android:id="@+id/etDay"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:inputType="number"
            android:hint="DD"/>

        <EditText
            android:id="@+id/etHour"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:inputType="number"
            android:hint="HH"/>

        <EditText
            android:id="@+id/etMinute"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:gravity="center"
            android:layout_margin="2dp"
            android:inputType="number"
            android:hint="MM"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnModifyYear"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:text="@string/modify"
            android:textColor="@color/blue"
            android:textSize="20sp"
            android:layout_margin="2dp"/>

        <Button
            android:id="@+id/btnModifyMonth"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:text="@string/modify"
            android:textColor="@color/blue"
            android:textSize="20sp"
            android:layout_margin="2dp"/>

        <Button
            android:id="@+id/btnModifyDay"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:text="@string/modify"
            android:textColor="@color/blue"
            android:textSize="20sp"
            android:layout_margin="2dp"/>

        <Button
            android:id="@+id/btnModifyHour"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:text="@string/modify"
            android:textColor="@color/blue"
            android:textSize="20sp"
            android:layout_margin="2dp"/>

        <Button
            android:id="@+id/btnModifyMinute"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="#FFFF0000"
            android:text="@string/modify"
            android:textColor="@color/blue"
            android:textSize="20sp"
            android:layout_margin="2dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FFFF0000"
        android:text="@string/save"
        android:textColor="@color/red"
        android:textSize="32sp"
        android:textStyle="bold"/>

</LinearLayout>